# 本地敏感配置模板：复制为 application-local.yml（已被 Git 忽略），填写真实值。
# 运行前在 IntelliJ「运行配置」→ Active profiles 填：local
# 或使用 VM options：-Dspring.profiles.active=local

cos:
  client:
    secretId: 请填写腾讯云 SecretId
    secretKey: 请填写腾讯云 SecretKey

aliYunAi:
  apiKey: 请填写阿里云百炼 / 通义等 API Key

# 若数据库密码与仓库默认不同，可在此覆盖，例如：
# spring:
#   datasource:
#     password: 你的密码
#   shardingsphere:
#     datasource:
#       yu_picture:
#         password: 你的密码
